# Optional Pi agent backend credentials (copy to config/pi_agent.env — do not commit secrets).
#
# Loaded by tools/config.py when APP_TYPE=pi (set automatically by agent-redact/pi/gradio_app.py,
# start.sh, and docker-compose pi-agent services). Override with APP_CONFIG_PATH if needed.
# APP_TYPE=pi also skips eager spaCy/Presidio load at startup (Pi orchestrates redaction remotely).
#
# Local Windows/macOS dev: leave unset to use {repo}/workspace (created automatically).
# Docker: compose sets PI_WORKSPACE_DIR=/home/user/app/workspace
# PI_WORKSPACE_DIR=
#
# Per-user session subfolders: {PI_WORKSPACE_DIR}/{gradio_session_hash}/ (default on).
# Set false only if you want one shared workspace tree for all browser sessions.
# PI_SESSION_WORKSPACE=true   # per-browser subfolder under workspace/ (default when unset)
# PI_SESSION_WORKSPACE=false  # single shared workspace root (legacy)
#
# Skills: on startup, repo skills/ are copied to {PI_WORKSPACE_DIR}/.pi/skills/ (read-only).
# Pi RPC uses --no-skills and loads only that folder; cwd is the session subfolder.
# PI_SKILLS_RESYNC=true   # force refresh from repo on next start
# PI_SKILLS_WRITABLE=true # skip read-only chmod (local debugging)
#
# Gradio upload temp (must match GRADIO_TEMP_DIR; local default: workspace/.gradio_uploads)
# PI_UPLOAD_ROOT=
# GRADIO_TEMP_DIR=
#
# Pi Gradio listen port (default 7862 local-docker, 7860 hf-space). Not GRADIO_SERVER_PORT (main app).
# PI_GRADIO_PORT=7862
#
# Monorepo root (skills/, config/). Usually auto-detected on Windows/macOS; Docker sets /workspace/doc_redaction.
# PI_WORKDIR=
#
# Host-only: path to pi RPC CLI if not on PATH (Windows: ...\AppData\Roaming\npm\pi.cmd)
# PI_EXECUTABLE=
#
# doc_redaction Gradio app for Pass 1 /doc_redact and review APIs (not the Pi UI above).
# Local dev: main app on 7860 → DOC_REDACTION_GRADIO_URL=http://127.0.0.1:7860
# Docker compose: http://redaction-app-llama:7860 (see docker-compose_llama_agentic.yml)
# AWS ECS (CDK sets this via Service Connect; upload this file to the log bucket as pi_agent.env):
# PI_DEPLOYMENT_PROFILE=aws-ecs
# PI_DEFAULT_PROVIDER=amazon-bedrock
# DOC_REDACTION_GRADIO_URL=http://redaction:7860
# DOC_REDACTION_GRADIO_URL=http://127.0.0.1:7860
#
# --- ALB / reverse-proxy subpath (set by CDK when PI_ALB_ROUTING includes path) ---
# PI_ROOT_PATH=/pi
# ROOT_PATH=/pi
# FASTAPI_ROOT_PATH=/pi
#
# Gradio UI on FastAPI (uvicorn). AWS ECS Pi tasks default RUN_FASTAPI=True via CDK (overrides this file).
# RUN_FASTAPI=False
#
# Session output upload (ECS/CDK sets RUN_AWS_FUNCTIONS, SAVE_OUTPUTS_TO_S3, S3_OUTPUTS_BUCKET on the task).
# RUN_AWS_FUNCTIONS=True
# SAVE_OUTPUTS_TO_S3=True
# S3_OUTPUTS_BUCKET=your-output-bucket-name
# S3_OUTPUTS_FOLDER=output
#
# --- Intro / branding (Pi Gradio UI) ---
# PI_GRADIO_TITLE=Agentic Document Redaction
# PI_INTRO_TEXT=intros/pi_intro.txt
# PI_INTRO_TEXT supports {USER_GUIDE_URL} and {PI_GRADIO_TITLE} when loading from a .txt file.
#
# Used by the pi-agent service in docker-compose_llama_agentic.yml.
# UI overrides in the Gradio app apply for the current container session only.

# Deployment profile: local-docker (default) | hf-space (Hugging Face Docker Space)
# PI_DEPLOYMENT_PROFILE=local-docker

# Default Pi orchestration backend: llama-cpp | google-gemini | amazon-bedrock
PI_DEFAULT_PROVIDER=llama-cpp
# PI_DEFAULT_MODEL=unsloth/Qwen3.6-27B-MTP-GGUF

# Default redaction task settings (Gradio UI + agent prompt; see agent-redact/pi/redaction_prompt.py)
# PI_DEFAULT_OCR_METHOD=hybrid-paddle-inference-server
# PI_DEFAULT_PII_METHOD=Local
# pi-bedrock compose profile overrides: AWS Textract service - all PDF types / AWS Comprehend
# pi-gemini compose profile overrides: tesseract / Local

# --- HF Space profile (PI_DEPLOYMENT_PROFILE=hf-space) ---
# PI_DEFAULT_PROVIDER=google-gemini
# PI_DEFAULT_MODEL=gemini-flash-latest
# HF Space: point DOC_REDACTION_GRADIO_URL at your doc_redaction Space (see top of file).
# HF_TOKEN=                          # auth to private redaction Space (Space secret on Pi Space)
# DOC_REDACTION_HF_TOKEN=            # alias mirrored to HF_TOKEN

# Local llama-cpp (match PI_LLAMA_MODEL_ID to the active compose profile / llama.cpp -hf repo)
# PI_LLAMA_BASE_URL=http://llama-inference:8080/v1
# PI_LLAMA_MODEL_ID=unsloth/Qwen3.6-27B-MTP-GGUF          # --profile 27b_36 (pi-agent)
# PI_LLAMA_MODEL_ID=unsloth/Qwen3.6-35B-A3B-GGUF           # --profile 35b_36 (pi-agent-35b)
# PI_LLAMA_MODEL_ID=unsloth/gemma-4-31B-it-GGUF           # --profile gemma4-31b (pi-agent-gemma-31b)
# PI_LLAMA_MODEL_ID=unsloth/gemma-4-26B-A4B-it-GGUF       # --profile gemma4-26b (pi-agent-gemma-26b)

# Google Gemini (Pi resolves GEMINI_API_KEY; GOOGLE_API_KEY is mirrored at startup)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
#
# Quota / rate-limit retries (Gradio UI loop and Pi auto-retry in settings.json; default 5)
# PI_MAX_RETRIES=5
# PI_QUOTA_RETRY_DELAY_S=60
# PI_GEMINI_RETRY_BASE_DELAY_MS=60000
# PI_GEMINI_RETRY_MAX_DELAY_MS=90000

# Pi session auto-compaction (written to ~/.pi/agent/settings.json on startup)
# PI_COMPACTION_ENABLED=true
# PI_COMPACTION_RESERVE_TOKENS=32768
# PI_COMPACTION_KEEP_RECENT_TOKENS=20000

# AWS Bedrock (uses AWS SDK credential chain — not a single API key)
# AWS_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=
