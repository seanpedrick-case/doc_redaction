# AWS deployment app settings (copy to cdk/config/app_config.env — do not commit secrets).
# Same variable names as config/app_config.env for local runs; loaded by ECS from S3 or Express env.
COGNITO_AUTH=True
RUN_AWS_FUNCTIONS=True
DISPLAY_FILE_NAMES_IN_LOGS=False
SESSION_OUTPUT_FOLDER=True
SAVE_LOGS_TO_CSV=True
SAVE_LOGS_TO_DYNAMODB=True
SHOW_COSTS=True
SHOW_WHOLE_DOCUMENT_TEXTRACT_CALL_OPTIONS=True
DOCUMENT_REDACTION_BUCKET=demo-redaction-s3-logs
TEXTRACT_WHOLE_DOCUMENT_ANALYSIS_BUCKET=demo-redaction-s3-output
ACCESS_LOG_DYNAMODB_TABLE_NAME=demo-redaction-dynamodb-access-logs
FEEDBACK_LOG_DYNAMODB_TABLE_NAME=demo-redaction-dynamodb-feedback-logs
USAGE_LOG_DYNAMODB_TABLE_NAME=demo-redaction-dynamodb-usage-logs
LOAD_PREVIOUS_TEXTRACT_JOBS_S3=True
LOG_FILE_NAME=log.csv
USAGE_LOG_FILE_NAME=usage_log.csv
FEEDBACK_LOG_FILE_NAME=feedback_log.csv
SHOW_LANGUAGE_SELECTION=True
SHOW_EXAMPLES=True
SHOW_AWS_EXAMPLES=True
RUN_ALL_EXAMPLES_THROUGH_AWS=True
EFFICIENT_OCR=True
HYBRID_TEXTRACT_BEDROCK_VLM=True
HYBRID_OCR_CONFIDENCE_THRESHOLD=95
CUSTOM_VLM_BACKEND=bedrock_vlm
SHOW_QUICKSTART=False
MAX_WORKERS=2
TESSERACT_MAX_WORKERS=2
PADDLE_MAX_WORKERS=1
SHOW_OCR_GUI_OPTIONS=True
INTRO_TEXT=intros/short_intro_responsible.txt
OVERWRITE_EXISTING_OCR_RESULTS=False
PREPROCESS_LOCAL_OCR_IMAGES=False
SHOW_SUMMARISATION=True
CLOUD_LLM_PII_MODEL_CHOICE=amazon.nova-pro-v1:0
CLOUD_LLM_PII_CUSTOM_INSTRUCTIONS_MODEL_CHOICE=anthropic.claude-sonnet-4-6
CLOUD_VLM_MODEL_CHOICE=amazon.nova-pro-v1:0
CLOUD_SUMMARISATION_MODEL_CHOICE=amazon.nova-lite-v1:0
ADD_VLM_BOUNDING_BOX_RULES=True
SAVE_TEXTRACT_BEDROCK_HYBRID_EXAMPLES=False
SHOW_BEDROCK_VLM_MODELS=True
LLM_MAX_NEW_TOKENS=8192
SHOW_AWS_BEDROCK_LLM_MODELS=True
CUSTOM_VLM_BACKEND=bedrock_vlm
SAVE_EXAMPLE_HYBRID_IMAGES=False
SAVE_PAGE_OCR_VISUALISATIONS=False
SAVE_PREPROCESS_IMAGES=False
SAVE_VLM_INPUT_IMAGES=False
SAVE_WORD_SEGMENTER_OUTPUT_IMAGES=False
SAVE_OUTPUTS_TO_S3=False
INCLUDE_FORM_EXTRACTION_TEXTRACT_OPTION=False
INCLUDE_LAYOUT_EXTRACTION_TEXTRACT_OPTION=False
INCLUDE_TABLE_EXTRACTION_TEXTRACT_OPTION=False
INCLUDE_FACE_IDENTIFICATION_TEXTRACT_OPTION=True
SHOW_WHOLE_DOCUMENT_TEXTRACT_CALL_OPTIONS=True
RUN_FASTAPI=True
GET_COST_CODES=False
PRIORITISE_SSO_OVER_AWS_ENV_ACCESS_KEYS=True
SESSION_OUTPUT_FOLDER=True
