# Example job file for headless batch redaction.
# 1. Upload your PDF to s3://<output-bucket>/input/
# 2. Copy this file, set DIRECT_MODE_INPUT_FILE to that PDF filename, save as my-job.env
# 3. Upload my-job.env to s3://<output-bucket>/input/config/ to start the ECS task.
#
# More DIRECT_MODE_* variables: tools/config.py in the doc_redaction repo.

DIRECT_MODE_TASK=redact
DIRECT_MODE_INPUT_FILE=your-document.pdf
SAVE_OUTPUTS_TO_S3=True
S3_OUTPUTS_FOLDER=output/
